# SIMP Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED
# ============================================

# Backend API URL (include /api path)
NEXT_PUBLIC_API_URL=https://localhost:5001/api

# ============================================
# OPTIONAL
# ============================================

# Application name displayed in UI
NEXT_PUBLIC_APP_NAME=SIMP

# Enable mock data for development (true/false)
NEXT_PUBLIC_ENABLE_MOCK=false

# Logging level (debug/info/warn/error)
NEXT_PUBLIC_LOG_LEVEL=info

# ============================================
# AZURE AD AUTHENTICATION (if using Azure AD)
# ============================================

# Azure AD Tenant ID
# NEXT_PUBLIC_AZURE_TENANT_ID=

# Azure AD Client ID
# NEXT_PUBLIC_AZURE_CLIENT_ID=

# Redirect URI after login
# NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================
# ANALYTICS & MONITORING (optional)
# ============================================

# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Analytics (automatically enabled on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
